#include <bits/stdc++.h>

using namespace std;

const int INF = 10000;
int n, u;
int c[100][100];
bool visited[100];
vector<int> path, bestPath;
int bestCost = INT_MAX;

void backtrack(int current, int count, int currentCost) {
    if (count == n) {
        if (c[current][u] != INF && c[current][u] != 0) {
            int totalCost = currentCost + c[current][u];
            if (totalCost < bestCost) {
                bestCost = totalCost;
                bestPath = path;
                bestPath.push_back(u);
            }
        }
        return;
    }

    for (int next = 1; next <= n; next++) {
        if (!visited[next] && c[current][next] != INF && c[current][next] != 0) {
            visited[next] = true;
            path.push_back(next);
            backtrack(next, count + 1, currentCost + c[current][next]);
            path.pop_back();
            visited[next] = false;
        }
    }
}
int main() {
    ifstream infile("CT.INP");
    ofstream outfile("CT.OUT");
    infile >> n >> u;
    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= n; j++) {
            infile >> c[i][j];
        }
    }
    for (int i = 1; i <= n; i++) visited[i] = false;
    visited[u] = true;
    path.clear();
    path.push_back(u);
    bestCost = INT_MAX;
    backtrack(u, 1, 0);
    if (bestCost == INT_MAX) {
        outfile << 0 << endl;
    } else {
        outfile << bestCost << endl;
        for (int i = 0; i < bestPath.size(); i++) {
            outfile << bestPath[i];
            if (i < bestPath.size() - 1) outfile << " ";
        }
        outfile << endl;
    }
    infile.close();
    outfile.close();
    return 0;
}
