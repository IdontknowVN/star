#include <bits/stdc++.h>
#define ll long long
using namespace std;

const ll INF = 1e15;

int main() {
    ifstream fin("CT.INP");
    ofstream fout("CT.OUT");
    
    int n, s, t;
    fin >> n >> s >> t;
    
    vector<vector<ll>> d(n + 1, vector<ll>(n + 1, INF));
    vector<vector<int>> nx(n + 1, vector<int>(n + 1, -1));
    
    for (int i = 1; i <= n; ++i) {
        for (int j = 1; j <= n; ++j) {
            ll x;
            fin >> x;
            if (i == j) {
                d[i][j] = 0;
                nx[i][j] = i;
            } else if (x != 10000) {
                d[i][j] = x;
                nx[i][j] = j;
            }
        }
    }
    
    for (int k = 1; k <= n; ++k)
        for (int i = 1; i <= n; ++i)
            for (int j = 1; j <= n; ++j)
                if (d[i][k] != INF && d[k][j] != INF)
                    if (d[i][k] + d[k][j] < d[i][j]) {
                        d[i][j] = d[i][k] + d[k][j];
                        nx[i][j] = nx[i][k];
                    }
    
    bool negCycle = false;
    for (int i = 1; i <= n; ++i)
        if (d[i][i] < 0) {
            negCycle = true;
            break;
        }
    
    if (negCycle) {
        fout << -1;
        return 0;
    }
    
    if (d[s][t] == INF) {
        fout << 0;
        return 0;
    }
    
    fout << d[s][t] << '\n';
    vector<int> path;
    int c = s;
    while (c != t) {
        path.push_back(c);
        c = nx[c][t];
    }
    path.push_back(t);
    
    for (int i = 0; i < (int)path.size(); ++i) {
        if (i) fout << ' ';
        fout << path[i];
    }
    
    return 0;
}
